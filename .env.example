# Environment overrides for meshcore-app.
# Nested config fields use a double-underscore separator.

# MESHCORE_APP_MQTT__HOST=localhost
# MESHCORE_APP_MQTT__PORT=1883
# MESHCORE_APP_MQTT__USERNAME=
# MESHCORE_APP_MQTT__PASSWORD=
# MESHCORE_APP_MQTT__CLIENT_ID=meshcore-app

# MESHCORE_APP_SERVICE__DB_PATH=./meshcore_app.sqlite3
# MESHCORE_APP_SERVICE__DEFAULT_TTL_S=30
# MESHCORE_APP_SERVICE__MAX_TTL_S=300
# MESHCORE_APP_SERVICE__LOG_LEVEL=INFO

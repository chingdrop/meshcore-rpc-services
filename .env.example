# Environment overrides for meshcore-rpc-services.
# Nested config uses "__" between levels.

# MQTT
# MESHCORE_RPC_SERVICES_MQTT__HOST=localhost
# MESHCORE_RPC_SERVICES_MQTT__PORT=1883
# MESHCORE_RPC_SERVICES_MQTT__USERNAME=
# MESHCORE_RPC_SERVICES_MQTT__PASSWORD=
# MESHCORE_RPC_SERVICES_MQTT__CLIENT_ID=meshcore-rpc-services
# MESHCORE_RPC_SERVICES_MQTT__QOS=1

# Service
# MESHCORE_RPC_SERVICES_SERVICE__DB_PATH=./data/meshcore_rpc_services.sqlite3
# MESHCORE_RPC_SERVICES_SERVICE__LOG_LEVEL=INFO

# Timeouts
# MESHCORE_RPC_SERVICES_SERVICE__TIMEOUTS__DEFAULT_S=30
# MESHCORE_RPC_SERVICES_SERVICE__TIMEOUTS__MIN_S=1
# MESHCORE_RPC_SERVICES_SERVICE__TIMEOUTS__MAX_S=300

# Retention
# MESHCORE_RPC_SERVICES_SERVICE__RETENTION__DAYS=30
# MESHCORE_RPC_SERVICES_SERVICE__RETENTION__INTERVAL_S=3600

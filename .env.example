# Environment overrides for meshcore-rpc-services.
# Nested config fields use a double-underscore separator.

# MESHCORE_RPC_SERVICES_MQTT__HOST=localhost
# MESHCORE_RPC_SERVICES_MQTT__PORT=1883
# MESHCORE_RPC_SERVICES_MQTT__USERNAME=
# MESHCORE_RPC_SERVICES_MQTT__PASSWORD=
# MESHCORE_RPC_SERVICES_MQTT__CLIENT_ID=meshcore-rpc-services

# MESHCORE_RPC_SERVICES_SERVICE__DB_PATH=./meshcore_rpc_services.sqlite3
# MESHCORE_RPC_SERVICES_SERVICE__DEFAULT_TTL_S=30
# MESHCORE_RPC_SERVICES_SERVICE__MAX_TTL_S=300
# MESHCORE_RPC_SERVICES_SERVICE__LOG_LEVEL=INFO
